//@version=6
indicator("Holo - Microestructura de Mercado", "Holo", overlay=true, max_labels_count=500, max_lines_count=500, max_boxes_count=500)

// ══════════════════════════════════════════════════════════════════════════════
// ENTRADAS
// ══════════════════════════════════════════════════════════════════════════════
grpMicro            = "🔬 Análisis de Microestructura"
microDepth          = input.int(50,   "Profundidad de análisis",       minval=20,  maxval=200, step=1,   group=grpMicro,
                                tooltip="Número de barras usadas para analizar el mercado")
liquidityThreshold  = input.float(1.5,"Umbral de vacío de liquidez",   minval=1.0, maxval=3.0, step=0.1, group=grpMicro,
                                tooltip="Multiplicador del ATR para detectar vacíos de liquidez (rangos amplios con bajo volumen)")
imbalanceRatio      = input.float(2.0,"Ratio de desequilibrio",        minval=1.5, maxval=5.0, step=0.1, group=grpMicro,
                                tooltip="Proporción mínima entre compras y ventas para detectar desequilibrio en el flujo")
mostrarVaciosLiq    = input.bool(true,"Mostrar vacíos de liquidez",    group=grpMicro,
                                tooltip="Resalta zonas donde el precio se movió rápido con poco volumen (posibles imanes de precio)")
mostrarFlujoOrdenes = input.bool(false,"Mostrar flujo de órdenes",     group=grpMicro,
                                tooltip="Colorea el fondo según el desequilibrio entre compradores y vendedores")

grpSmart            = "🧠 Seguimiento de Dinero Inteligente"
smartMoneyLength    = input.int(20,  "Período dinero inteligente",    minval=10, maxval=100, group=grpSmart,
                                tooltip="Número de barras para calcular tendencia de precio y volumen del dinero institucional")
accumThreshold      = input.float(70,"Umbral de acumulación (%)",     minval=50, maxval=90,  group=grpSmart,
                                tooltip="Variación mínima de volumen (%) para detectar acumulación o distribución institucional")
mostrarDineroIntelig= input.bool(true,"Mostrar zonas de dinero inteligente", group=grpSmart,
                                tooltip="Resalta zonas donde se detectó actividad institucional (acumulación o distribución)")
mostrarDivergencia  = input.bool(true,"Mostrar divergencia precio/volumen",  group=grpSmart,
                                tooltip="Señala cuando el precio sube pero el volumen cae (o viceversa) — posible agotamiento de tendencia")

grpFractal          = "🌀 Estructura Fractal"
fractalPeriod       = input.int(5,  "Período del fractal",            minval=3,  maxval=15, group=grpFractal,
                                tooltip="Barras a cada lado para confirmar un máximo o mínimo fractal")
structureDepth      = input.int(3,  "Profundidad de estructura",      minval=1,  maxval=5,  group=grpFractal,
                                tooltip="Cuántos fractales anteriores se conectan para formar la estructura de mercado")
mostrarFractales    = input.bool(true,"Mostrar niveles fractales",     group=grpFractal,
                                tooltip="Dibuja puntos en los máximos y mínimos fractales confirmados")
mostrarEstructura   = input.bool(true,"Mostrar estructura de mercado", group=grpFractal,
                                tooltip="Conecta fractales para visualizar la secuencia de máximos y mínimos del mercado")

grpHeat             = "🔥 Mapa de Calor de Volumen"
heatmapBars         = input.int(100,"Barras del mapa de calor",       minval=50, maxval=300, group=grpHeat,
                                tooltip="Número de barras hacia atrás para construir el perfil de volumen por precio")
heatmapLevels       = input.int(10, "Niveles del mapa de calor",      minval=5,  maxval=20,  group=grpHeat,
                                tooltip="Cuántas franjas de precio se dividen para mostrar la concentración de volumen")
mostrarMapaCalor    = input.bool(true,"Mostrar mapa de calor",         group=grpHeat,
                                tooltip="Muestra barras horizontales que indican dónde se concentró más volumen")
opacidadMapa        = input.int(95, "Opacidad del mapa (%)",          minval=50, maxval=100, group=grpHeat,
                                tooltip="Transparencia del mapa de calor — valores bajos lo hacen más visible")

grpVisual           = "💎 Visuales Holográficos"
tema                = input.string("Aeon","Tema visual", options=["Aeon","Cyber","Quantum","Neural","Plasma","Crystal"], group=grpVisual,
                                tooltip="Paleta de colores del indicador")
efectoBrillo        = input.bool(true,"Activar efecto de brillo",      group=grpVisual,
                                tooltip="Agrega una línea extra gruesa detrás de la estructura para simular resplandor")
efectoPulso         = input.bool(true,"Activar efecto de pulso",       group=grpVisual,
                                tooltip="Dibuja una capa adicional en los vacíos de liquidez para reforzar la señal visual")
mostrarHUD          = input.bool(true,"Mostrar panel de información",  group=grpVisual,
                                tooltip="Muestra un resumen en pantalla del estado actual del mercado")
posicionHUD         = input.string("middle_right","Posición del panel",
                                options=["top_left","top_right","middle_left","middle_right"], group=grpVisual,
                                tooltip="Ubicación del panel de información en el gráfico")
mostrarGlosario     = input.bool(false,"Mostrar glosario de términos",  group=grpVisual,
                                tooltip="Despliega una tabla explicando qué significa cada término del indicador")
posicionGlosario    = input.string("top_right","Posición del glosario",
                                options=["top_left","top_right","bottom_left","bottom_right"], group=grpVisual,
                                tooltip="Ubicación de la tabla de glosario en el gráfico")

// ══════════════════════════════════════════════════════════════════════════════
// TEMAS DE COLOR
// ══════════════════════════════════════════════════════════════════════════════
[primario, secundario, acento, brillo, oscuro] = switch tema
    "Aeon"    => [#4cc9f0, #f72585, #4361ee, #7209b7, #3a0ca3]
    "Cyber"   => [#00ffff, #ff00ff, #ffff00, #00ff00, #000033]
    "Quantum" => [#4169e1, #ff1493, #00ff7f, #ffa500, #000022]
    "Neural"  => [#7fff00, #ff69b4, #00ced1, #ffd700, #001122]
    "Plasma"  => [#ff00ff, #00ffff, #ff69b4, #7fff00, #110022]
    =>           [#00bfff, #ff6347, #32cd32, #ffd700, #000044]

holo1 = color.from_gradient(50, 0, 100, color.new(primario,   90), color.new(secundario, 70))
holo2 = color.from_gradient(70, 0, 100, color.new(secundario, 85), color.new(acento,     75))
holo3 = color.from_gradient(30, 0, 100, color.new(acento,     95), color.new(brillo,     80))

// ══════════════════════════════════════════════════════════════════════════════
// CÁLCULOS
// ══════════════════════════════════════════════════════════════════════════════
var float[] perfilVolumen = array.new_float(heatmapLevels, 0)
var float[] perfilPrecio  = array.new_float(heatmapLevels, 0)

maximo     = ta.highest(high, heatmapBars)
minimo     = ta.lowest(low,   heatmapBars)
rangoPrecio= maximo - minimo
alturaNivel= rangoPrecio / heatmapLevels

if barstate.isconfirmed
    for i = 0 to heatmapLevels - 1
        array.set(perfilVolumen, i, 0)
        array.set(perfilPrecio,  i, minimo + (i * alturaNivel) + alturaNivel / 2)

for j = 0 to math.min(heatmapBars - 1, bar_index)
    precioBar   = (high[j] + low[j]) / 2
    volBar      = volume[j]
    idxNivel    = int((precioBar - minimo) / alturaNivel)
    if idxNivel >= 0 and idxNivel < heatmapLevels
        array.set(perfilVolumen, idxNivel, array.get(perfilVolumen, idxNivel) + volBar)

volCompras  = volume * (close - low)  / (high - low)
volVentas   = volume * (high - close) / (high - low)
desequilib  = volCompras - volVentas
ofi         = ta.cum(desequilib)
ofiMA       = ta.sma(ofi, smartMoneyLength)

atrProm        = ta.atr(14)
umbralVacio    = atrProm * liquidityThreshold
smaVol20       = ta.sma(volume, 20)
esVacioLiq     = (high - low) > umbralVacio and volume < smaVol20 * 0.7

rocPrecio      = ta.roc(close,  smartMoneyLength)
rocVolumen     = ta.roc(volume, smartMoneyLength)
idxDineroInt   = (rocPrecio > 0 and rocVolumen > accumThreshold) ? 1 :
                 (rocPrecio < 0 and rocVolumen > accumThreshold) ? -1 : 0

fractalAlto    = high[fractalPeriod] == ta.highest(high, fractalPeriod * 2 + 1)
fractalBajo    = low[fractalPeriod]  == ta.lowest(low,   fractalPeriod * 2 + 1)

var float[] estructuraAltos    = array.new_float(structureDepth, na)
var float[] estructuraBajos    = array.new_float(structureDepth, na)
var int[]   tiemposAltos       = array.new_int(structureDepth, 0)
var int[]   tiemposBajos       = array.new_int(structureDepth, 0)

if fractalAlto
    array.shift(estructuraAltos)
    array.push( estructuraAltos,  high[fractalPeriod])
    array.shift(tiemposAltos)
    array.push( tiemposAltos,     bar_index - fractalPeriod)

if fractalBajo
    array.shift(estructuraBajos)
    array.push( estructuraBajos,  low[fractalPeriod])
    array.shift(tiemposBajos)
    array.push( tiemposBajos,     bar_index - fractalPeriod)

microTendencia = 0
for i = 0 to structureDepth - 2
    if not na(array.get(estructuraAltos, i)) and not na(array.get(estructuraAltos, i + 1))
        microTendencia += array.get(estructuraAltos, i) > array.get(estructuraAltos, i + 1) ? 1 : -1
    if not na(array.get(estructuraBajos, i))  and not na(array.get(estructuraBajos, i + 1))
        microTendencia += array.get(estructuraBajos, i) > array.get(estructuraBajos, i + 1) ? 1 : -1

var bool hasDivergencia = false
tendenciaPrecio  = ta.linreg(close,  smartMoneyLength, 0)
tendenciaVolumen = ta.linreg(volume, smartMoneyLength, 0)
hasDivergencia  := mostrarDivergencia and
                   ((tendenciaPrecio > 0 and tendenciaVolumen < 0) or
                    (tendenciaPrecio < 0 and tendenciaVolumen > 0))

// ══════════════════════════════════════════════════════════════════════════════
// VISUALIZACIÓN
// ══════════════════════════════════════════════════════════════════════════════
if mostrarMapaCalor
    maxVol = array.max(perfilVolumen)
    for i = 0 to heatmapLevels - 1
        nivelVol   = array.get(perfilVolumen, i)
        nivelPrecio= array.get(perfilPrecio,  i)
        ratioVol   = nivelVol / maxVol
        colorCalor = color.from_gradient(ratioVol * 100, 0, 100,
                         color.new(oscuro, 95), color.new(brillo, opacidadMapa))
        anchoBox   = int(ratioVol * 40)
        if nivelVol > 0
            box.new(bar_index - anchoBox, nivelPrecio + alturaNivel / 2,
                    bar_index,            nivelPrecio - alturaNivel / 2,
                    bgcolor=colorCalor, border_color=color.new(primario, 90))

if mostrarVaciosLiq and esVacioLiq[1]
    box.new(bar_index - 1, high[1], bar_index, low[1],
            bgcolor=color.new(acento, 95), border_color=color.new(acento, 50))
    if efectoPulso
        box.new(bar_index - 1, high[1], bar_index, low[1],
                bgcolor=color.new(acento, 98), border_color=color.new(acento, 80))

ofiNormalizado = (ofi - ofiMA) / ta.stdev(ofi - ofiMA, smartMoneyLength)

plot(mostrarFlujoOrdenes ? ofi   : na, "Flujo de órdenes",    color=color.new(primario,   100), display=display.none)
plot(mostrarFlujoOrdenes ? ofiMA : na, "MA Flujo de órdenes", color=color.new(secundario, 100), display=display.none)
bgcolor(mostrarFlujoOrdenes ?
        color.new(ofiNormalizado > 0 ? primario : secundario,
                  95 - math.abs(ofiNormalizado) * 10) : na)

if mostrarDineroIntelig and idxDineroInt != 0
    zonaColor = idxDineroInt == 1 ? primario : secundario
    for i = 0 to 4
        alfa = 95 - i * 5
        box.new(bar_index - smartMoneyLength + i * 5, high,
                bar_index - smartMoneyLength + i * 5 + 5, low,
                bgcolor=color.new(zonaColor, alfa), border_color=na)

if mostrarEstructura
    for i = 0 to structureDepth - 2
        if not na(array.get(estructuraAltos, i)) and not na(array.get(estructuraAltos, i + 1))
            line.new(array.get(tiemposAltos, i),   array.get(estructuraAltos, i),
                     array.get(tiemposAltos, i+1), array.get(estructuraAltos, i+1),
                     color=color.new(primario, 70), width=2, style=line.style_dashed)
            if efectoBrillo
                line.new(array.get(tiemposAltos, i),   array.get(estructuraAltos, i),
                         array.get(tiemposAltos, i+1), array.get(estructuraAltos, i+1),
                         color=color.new(brillo, 90), width=4, style=line.style_dashed)
        if not na(array.get(estructuraBajos, i)) and not na(array.get(estructuraBajos, i + 1))
            line.new(array.get(tiemposBajos, i),   array.get(estructuraBajos, i),
                     array.get(tiemposBajos, i+1), array.get(estructuraBajos, i+1),
                     color=color.new(secundario, 70), width=2, style=line.style_dashed)
            if efectoBrillo
                line.new(array.get(tiemposBajos, i),   array.get(estructuraBajos, i),
                         array.get(tiemposBajos, i+1), array.get(estructuraBajos, i+1),
                         color=color.new(brillo, 90), width=4, style=line.style_dashed)

plotshape(mostrarFractales and fractalAlto,
          title="Fractal alto", location=location.abovebar,
          color=color.new(primario, 30), size=size.tiny, offset=-fractalPeriod)
plotshape(mostrarFractales and fractalBajo,
          title="Fractal bajo",  location=location.belowbar,
          color=color.new(secundario, 30), size=size.tiny, offset=-fractalPeriod)

if mostrarDivergencia and hasDivergencia
    label.new(bar_index, high, "⚠",
              color=color.new(acento, 0), textcolor=acento,
              style=label.style_none, size=size.large)

// ══════════════════════════════════════════════════════════════════════════════
// SEÑAL DE ENTRADA
// ══════════════════════════════════════════════════════════════════════════════
// Condiciones LONG (5 puntos posibles)
cL1 = ofiNormalizado > 1                                                    // Flujo comprando
cL2 = idxDineroInt == 1                                                     // Smart$ acumulando
cL3 = microTendencia > 2                                                    // Estructura alcista
cL4 = not esVacioLiq or (esVacioLiq[1] and (high[1] + low[1]) / 2 > close) // Liquidez libre arriba o normal
cL5 = not hasDivergencia                                                    // Sin divergencia

longPts = (cL1 ? 1 : 0) + (cL2 ? 1 : 0) + (cL3 ? 1 : 0) + (cL4 ? 1 : 0) + (cL5 ? 1 : 0)
longSig = cL1 and cL3 and longPts >= 3   // minimo: Flow + Estructura alcista + 1 mas

// Condiciones SHORT (5 puntos posibles)
cS1 = ofiNormalizado < -1                                                   // Flujo vendiendo
cS2 = idxDineroInt == -1                                                    // Smart$ distribuyendo
cS3 = microTendencia < -2                                                   // Estructura bajista
cS4 = esVacioLiq[1] and (high[1] + low[1]) / 2 < close                     // Vacío de liquidez abajo
cS5 = not hasDivergencia                                                    // Sin divergencia

shortPts = (cS1 ? 1 : 0) + (cS2 ? 1 : 0) + (cS3 ? 1 : 0) + (cS4 ? 1 : 0) + (cS5 ? 1 : 0)
shortSig = cS1 and cS3 and shortPts >= 3  // minimo: Flow + Estructura bajista + 1 mas

// Signal final (long tiene prioridad si ambos empatan)
_conflicto = (cL1 and cS2) or (cS1 and cL2)                                // Módulos en conflicto → no operar
signalFinal = longSig and not _conflicto ? 1 : shortSig and not _conflicto ? -1 : 0

// ══════════════════════════════════════════════════════════════════════════════
// PANEL DE INFORMACIÓN (HUD)
// ══════════════════════════════════════════════════════════════════════════════
if mostrarHUD
    posHUD = switch posicionHUD
        "top_left"    => position.top_left
        "top_right"   => position.top_right
        "middle_left" => position.middle_left
        =>              position.middle_right

    var table hud = table.new(posHUD, 2, 8)
    fondoHUD  = color.new(oscuro, 90)

    table.cell(hud, 0, 0, "MICROESTRUCTURA", bgcolor=fondoHUD, text_color=primario, text_size=size.normal)
    table.cell(hud, 1, 0, "",                bgcolor=fondoHUD, text_color=primario, text_size=size.normal)

    textoFlujo = ofiNormalizado > 1 ? "▲ COMPRANDO" : ofiNormalizado < -1 ? "▼ VENDIENDO" : "◆ NEUTRAL"
    colorFlujo = ofiNormalizado > 1 ? primario       : ofiNormalizado < -1 ? secundario     : acento
    table.cell(hud, 0, 1, "Flujo:",     bgcolor=fondoHUD, text_color=color.gray, text_size=size.small)
    table.cell(hud, 1, 1, textoFlujo,  bgcolor=fondoHUD, text_color=colorFlujo, text_size=size.small)

    textoEst = microTendencia > 2 ? "▲ ALCISTA" : microTendencia < -2 ? "▼ BAJISTA" : "◆ LATERAL"
    colorEst = microTendencia > 2 ? primario     : microTendencia < -2 ? secundario   : acento
    table.cell(hud, 0, 2, "Estructura:", bgcolor=fondoHUD, text_color=color.gray, text_size=size.small)
    table.cell(hud, 1, 2, textoEst,     bgcolor=fondoHUD, text_color=colorEst,   text_size=size.small)

    textoDInt = idxDineroInt == 1 ? "◈ ACUMULANDO" : idxDineroInt == -1 ? "◈ DISTRIBUYENDO" : "○ SIN SEÑAL"
    colorDInt = idxDineroInt == 1 ? primario        : idxDineroInt == -1 ? secundario          : color.gray
    table.cell(hud, 0, 3, "D.Intelig.:", bgcolor=fondoHUD, text_color=color.gray, text_size=size.small)
    table.cell(hud, 1, 3, textoDInt,    bgcolor=fondoHUD, text_color=colorDInt,  text_size=size.small)

    textoLiq = esVacioLiq ? "⚡ VACÍO" : "● NORMAL"
    table.cell(hud, 0, 4, "Liquidez:",  bgcolor=fondoHUD, text_color=color.gray, text_size=size.small)
    table.cell(hud, 1, 4, textoLiq,    bgcolor=fondoHUD,
               text_color=esVacioLiq ? acento : color.gray, text_size=size.small)

    textoDiv = hasDivergencia ? "⚠ ALERTA" : "✓ OK"
    table.cell(hud, 0, 5, "Divergencia:", bgcolor=fondoHUD, text_color=color.gray, text_size=size.small)
    table.cell(hud, 1, 5, textoDiv,      bgcolor=fondoHUD,
               text_color=hasDivergencia ? brillo : color.gray, text_size=size.small)

    // Fila separadora
    table.cell(hud, 0, 6, "─────────────", bgcolor=color.new(oscuro, 70), text_color=color.new(primario, 60), text_size=size.tiny)
    table.cell(hud, 1, 6, "─────────────", bgcolor=color.new(oscuro, 70), text_color=color.new(primario, 60), text_size=size.tiny)

    // Signal final
    _ptsActivos  = signalFinal == 1 ? longPts  : signalFinal == -1 ? shortPts : 0
    _textoSenhal = signalFinal == 1 ? "◉ COMPRAR" : signalFinal == -1 ? "◉ VENDER" :
                   _conflicto      ? "⚡ CONFLICTO" :
                   idxDineroInt == 0 or (microTendencia >= -2 and microTendencia <= 2) ?
                   "◯ ESPERAR" : "◯ ESPERAR"
    _colorSenhal = signalFinal == 1 ? primario : signalFinal == -1 ? secundario :
                   _conflicto      ? acento   : color.gray
    _bgSenhal    = signalFinal == 1 ? color.new(primario, 75) : signalFinal == -1 ? color.new(secundario, 75) :
                   color.new(oscuro, 70)
    _textoPts    = signalFinal != 0 ? str.tostring(_ptsActivos) + "/5 condiciones" : "—"
    table.cell(hud, 0, 7, _textoSenhal, bgcolor=_bgSenhal, text_color=_colorSenhal, text_size=size.small)
    table.cell(hud, 1, 7, _textoPts,    bgcolor=_bgSenhal, text_color=color.white,  text_size=size.small)

// ══════════════════════════════════════════════════════════════════════════════
// GLOSARIO DE TÉRMINOS
// ══════════════════════════════════════════════════════════════════════════════
if mostrarGlosario
    posG = switch posicionGlosario
        "top_left"     => position.top_left
        "top_right"    => position.top_right
        "bottom_right" => position.bottom_right
        =>               position.bottom_left

    var table glosario = table.new(posG, 2, 11, border_width=1, border_color=color.new(primario, 60))
    bg0 = color.new(oscuro, 80)
    bg1 = color.new(oscuro, 88)

    // Encabezado
    table.cell(glosario, 0, 0, "TÉRMINO",      bgcolor=color.new(primario, 40), text_color=color.white,  text_size=size.small)
    table.cell(glosario, 1, 0, "SIGNIFICADO",  bgcolor=color.new(primario, 40), text_color=color.white,  text_size=size.small)

    // Vacío de liquidez
    table.cell(glosario, 0, 1, "Vacío de liquidez", bgcolor=bg0, text_color=acento,      text_size=size.small)
    table.cell(glosario, 1, 1, "Vela de rango amplio con volumen bajo. El precio suele\nvolver a rellenarlo.", bgcolor=bg0, text_color=color.white, text_size=size.small)

    // Flujo de órdenes
    table.cell(glosario, 0, 2, "Flujo de órdenes", bgcolor=bg1, text_color=primario,    text_size=size.small)
    table.cell(glosario, 1, 2, "Diferencia acumulada entre presión compradora y vendedora\npor barra.", bgcolor=bg1, text_color=color.white, text_size=size.small)

    // Acumulación
    table.cell(glosario, 0, 3, "Acumulando",        bgcolor=bg0, text_color=primario,    text_size=size.small)
    table.cell(glosario, 1, 3, "Institucionales comprando en silencio. Precio estable\no bajando con volumen creciente.", bgcolor=bg0, text_color=color.white, text_size=size.small)

    // Distribución
    table.cell(glosario, 0, 4, "Distribuyendo",     bgcolor=bg1, text_color=secundario,  text_size=size.small)
    table.cell(glosario, 1, 4, "Institucionales vendiendo en silencio. Precio subiendo\npero volumen señala salida de dinero.", bgcolor=bg1, text_color=color.white, text_size=size.small)

    // Fractal
    table.cell(glosario, 0, 5, "Fractal",           bgcolor=bg0, text_color=color.white, text_size=size.small)
    table.cell(glosario, 1, 5, "Máximo o mínimo local confirmado por N barras a cada\nlado — punto de referencia de estructura.", bgcolor=bg0, text_color=color.white, text_size=size.small)

    // Estructura alcista
    table.cell(glosario, 0, 6, "Estructura alcista", bgcolor=bg1, text_color=primario,   text_size=size.small)
    table.cell(glosario, 1, 6, "Secuencia de máximos y mínimos ascendentes (HH + HL).\nEl mercado está en tendencia al alza.", bgcolor=bg1, text_color=color.white, text_size=size.small)

    // Estructura bajista
    table.cell(glosario, 0, 7, "Estructura bajista", bgcolor=bg0, text_color=secundario, text_size=size.small)
    table.cell(glosario, 1, 7, "Secuencia de máximos y mínimos descendentes (LH + LL).\nEl mercado está en tendencia a la baja.", bgcolor=bg0, text_color=color.white, text_size=size.small)

    // Estructura lateral
    table.cell(glosario, 0, 8, "Estructura lateral", bgcolor=bg1, text_color=acento,     text_size=size.small)
    table.cell(glosario, 1, 8, "Sin secuencia clara de máximos/mínimos. El mercado\nse mueve en rango sin dirección definida.", bgcolor=bg1, text_color=color.white, text_size=size.small)

    // Divergencia
    table.cell(glosario, 0, 9, "Divergencia",        bgcolor=bg0, text_color=brillo,     text_size=size.small)
    table.cell(glosario, 1, 9, "El precio y el volumen van en sentidos opuestos.\nSeñal de posible agotamiento o reversión.", bgcolor=bg0, text_color=color.white, text_size=size.small)

    // Mapa de calor
    table.cell(glosario, 0, 10, "Mapa de calor",     bgcolor=bg1, text_color=color.white, text_size=size.small)
    table.cell(glosario, 1, 10, "Perfil de volumen por precio. Las zonas más brillantes\nconcentran más actividad — son soportes/resistencias clave.", bgcolor=bg1, text_color=color.white, text_size=size.small)

// ══════════════════════════════════════════════════════════════════════════════
// ALERTAS
// ══════════════════════════════════════════════════════════════════════════════
alertcondition(esVacioLiq,
               "Vacío de liquidez detectado",
               "Holo: Se formó un vacío de liquidez — el precio se movió rápido con bajo volumen (posible imán de precio)")

alertcondition(math.abs(ofiNormalizado) > 2,
               "Flujo de órdenes extremo",
               "Holo: Desequilibrio fuerte entre compradores y vendedores — posible movimiento direccional inminente")

alertcondition(idxDineroInt != 0,
               "Actividad de dinero institucional",
               "Holo: Se detectó acumulación o distribución institucional — observa si el precio confirma la dirección")

alertcondition(hasDivergencia,
               "Divergencia precio / volumen",
               "Holo: El precio y el volumen se mueven en direcciones opuestas — posible agotamiento o reversión de tendencia")

alertcondition(microTendencia > 3 or microTendencia < -3,
               "Cambio de estructura de mercado",
               "Holo: La secuencia de máximos y mínimos cambió — posible inicio de nueva tendencia")
