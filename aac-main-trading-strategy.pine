//@version=5
// ================================================================
// AAC Main Trading Strategy
// Version   : 1.0
// Author    : Andrey Alvarado
// Description:
//   Framework principal de estrategias de trading.
//   Contiene logica compartida (riesgo, visual, backtesting)
//   y modulos de estrategia activables individualmente.
//
//   Modulos disponibles:
//     [1] AAC Scalping - Supply & Demand (zones)
//
//   Para agregar una nueva estrategia, seguir el patron del
//   bloque MODULE e integrar sus senales en SIGNAL AGGREGATION.
// ================================================================
strategy(title="AAC Main Trading Strategy",
     shorttitle="AAC-MAIN",
     overlay=true,
     initial_capital=10000,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=1,
     commission_type=strategy.commission.percent,
     commission_value=0.05,
     slippage=2,
     max_bars_back=500,
     pyramiding=0)

// ================================================================
// === SHARED - Backtesting Window
// ================================================================
var g_bt     = "Backtesting"
i_bt_from    = input.time(timestamp("2022-01-01"), "From Date", group=g_bt)
i_bt_to      = input.time(timestamp("2026-12-31"), "To Date",   group=g_bt)
in_bt_window = time >= i_bt_from and time <= i_bt_to

// ================================================================
// === SHARED - Trend
// ================================================================
var g_trend      = "Trend"
i_ma_type        = input.string("EMA", "MA Type", options=["EMA","SMA","WMA"], group=g_trend)
i_ma_fast        = input.int(20, "Fast MA Length", minval=2, group=g_trend)
i_ma_slow        = input.int(50, "Slow MA Length", minval=2, group=g_trend)
i_use_trend      = input.bool(true, "Filter by Trend", group=g_trend)
i_strict_trend   = input.bool(false, "Strict Trend (close must be above/below Slow MA)", group=g_trend)

// ================================================================
// === SHARED - Risk Management
// ================================================================
var g_risk   = "Risk"
i_sl_mult    = input.float(1.5, "Stop Loss (ATR mult)", minval=0.1, step=0.1, group=g_risk)
i_rr         = input.float(2.0, "Risk / Reward Ratio", minval=0.5, step=0.1, group=g_risk)
i_risk_pct   = input.float(1.0, "Risk % per Trade (of equity)", minval=0.1, maxval=10.0, step=0.1, group=g_risk)
i_use_trail  = input.bool(false, "Use Trailing Stop", group=g_risk)
i_trail_mult = input.float(1.0, "Trailing Distance (ATR mult)", minval=0.1, step=0.1, group=g_risk)
i_cooldown   = input.int(0, "Entry Cooldown (bars after last entry)", minval=0, step=1, group=g_risk)

// ================================================================
// === SHARED - Session Filter
// ================================================================
var g_session  = "Session"
i_filter_sess  = input.bool(false, "Filter by Session", group=g_session)
i_session      = input.session("0930-1600", "Trading Session", group=g_session)
i_tz           = input.string("America/New_York", "Timezone", group=g_session)

// ================================================================
// === SHARED - Visual
// ================================================================
var g_vis     = "Visual"
i_show_mas    = input.bool(true, "Show Moving Averages", group=g_vis)
i_show_labels = input.bool(true, "Show BUY/SELL Labels", group=g_vis)
i_show_rr     = input.bool(true, "Show R/R Trade Boxes", group=g_vis)
i_transp_box  = input.int(75, "Trade Box Transparency", minval=50, maxval=95, group=g_vis)

// ================================================================
// === SHARED - Analyzer Table
// ================================================================
var g_tbl      = "Analyzer"
i_show_table   = input.bool(true,  "Show Strategy Analyzer Table", group=g_tbl)
i_auto_suggest = input.bool(false, "Auto-Suggest: Apply Recommended Values", group=g_tbl)

// ================================================================
// === SHARED - Debug
// ================================================================
var g_dbg = "Debug"
i_debug   = input.bool(false, "Show Debug Labels", group=g_dbg)

// ================================================================
// === SHARED - Calculations
// ================================================================

atr14 = ta.atr(14)

_ma(src, len, t) =>
    switch t
        "EMA" => ta.ema(src, len)
        "SMA" => ta.sma(src, len)
        "WMA" => ta.wma(src, len)
        =>       ta.ema(src, len)

fast_ma   = _ma(close, i_ma_fast, i_ma_type)
slow_ma   = _ma(close, i_ma_slow, i_ma_type)
bull_bias = fast_ma > slow_ma
bear_bias = fast_ma < slow_ma

in_session     = i_filter_sess ? not na(time(timeframe.period, i_session, i_tz)) : true
trend_ok_long  = not i_use_trend or (bull_bias and (not i_strict_trend or close > slow_ma))
trend_ok_short = not i_use_trend or (bear_bias and (not i_strict_trend or close < slow_ma))
no_position    = strategy.position_size == 0
var int   _last_entry_bar = -999
var float _entry_tp       = na
var float _entry_sl       = na
cooldown_ok    = bar_index - _last_entry_bar > i_cooldown

// Auto-suggest: TF-based recommended values (applied when i_auto_suggest is ON)
_as_tf   = timeframe.period
_as_piv  = _as_tf == "1" ? 3 : _as_tf == "3" ? 3 : _as_tf == "5" ? 4 : _as_tf == "15" ? 5 : _as_tf == "30" ? 6 : _as_tf == "60" ? 7 : _as_tf == "240" ? 8 : 5
_as_zatr = _as_tf == "1" ? 0.3 : _as_tf == "3" ? 0.35 : _as_tf == "5" ? 0.4 : _as_tf == "15" ? 0.5 : _as_tf == "30" ? 0.6 : _as_tf == "60" ? 0.7 : _as_tf == "240" ? 0.8 : 0.5
_as_sl   = _as_tf == "1" ? 1.0 : _as_tf == "3" ? 1.0 : _as_tf == "5" ? 1.2 : _as_tf == "15" ? 1.5 : _as_tf == "30" ? 1.8 : _as_tf == "60" ? 2.0 : _as_tf == "240" ? 2.5 : 1.5
_as_rr   = _as_tf == "1" ? 1.5 : _as_tf == "3" ? 1.5 : _as_tf == "5" ? 1.8 : _as_tf == "15" ? 2.0 : _as_tf == "30" ? 2.0 : _as_tf == "60" ? 2.5 : _as_tf == "240" ? 2.5 : 2.0
_as_tch  = (_as_tf == "1" or _as_tf == "3" or _as_tf == "5") ? "Rejection Bar" : "Wick Touch"

eff_sl_m = i_auto_suggest ? _as_sl : i_sl_mult
eff_rr_v = i_auto_suggest ? _as_rr : i_rr
sl_dist  = atr14 * eff_sl_m
tp_dist  = sl_dist * eff_rr_v

// ================================================================
// ================================================================
// === MODULE 1: AAC Scalping - Supply & Demand
// ================================================================
// ================================================================

var g_s1       = "AAC Scalping - Supply & Demand"
i_s1_enable    = input.bool(true, "--- Enable AAC Scalping ---", group=g_s1)
i_s1_pivot_l   = input.int(5, "Pivot Left Bars", minval=1, group=g_s1)
i_s1_pivot_r   = input.int(5, "Pivot Right Bars", minval=1, group=g_s1)
i_s1_zone_atr  = input.float(0.5, "Zone Width (ATR mult)", minval=0.1, step=0.05, group=g_s1)
i_s1_extend    = input.int(100, "Zone Extension (bars right)", minval=10, group=g_s1)
i_s1_max_zones = input.int(3, "Max Active Zones per Side", minval=1, maxval=5, group=g_s1)
i_s1_inval      = input.bool(true, "Invalidate on Body Close-Through", group=g_s1)
i_s1_touch      = input.string("Rejection Bar", "Entry Trigger", options=["Wick Touch","Rejection Bar","Body Close Inside"], group=g_s1)
i_s1_max_uses   = input.int(2, "Max Signals per Zone", minval=1, maxval=10, group=g_s1)
i_s1_min_room   = input.int(50, "Min Room to Opposing Zone (ticks)", minval=0, group=g_s1)
i_s1_longs      = input.bool(true, "Enable Longs", group=g_s1)
i_s1_shorts     = input.bool(true, "Enable Shorts", group=g_s1)
i_s1_transp_z  = input.int(82, "Zone Transparency", minval=50, maxval=95, group=g_s1)

// Effective Module 1 parameters (override with suggested values when Auto-Suggest is ON)
eff_pivot_l = i_auto_suggest ? _as_piv  : i_s1_pivot_l
eff_pivot_r = i_auto_suggest ? _as_piv  : i_s1_pivot_r
eff_zatr    = i_auto_suggest ? _as_zatr : i_s1_zone_atr
eff_touch   = i_auto_suggest ? _as_tch  : i_s1_touch

// --- Zone Arrays
var float[] s1_sz_top   = array.new_float()
var float[] s1_sz_bot   = array.new_float()
var int[]   s1_sz_bar   = array.new_int()
var bool[]  s1_sz_alive = array.new_bool()
var int[]   s1_sz_uses  = array.new_int()

var float[] s1_dz_top   = array.new_float()
var float[] s1_dz_bot   = array.new_float()
var int[]   s1_dz_bar   = array.new_int()
var bool[]  s1_dz_alive = array.new_bool()
var int[]   s1_dz_uses  = array.new_int()

// --- Pivot Detection
s1_ph        = ta.pivothigh(high, eff_pivot_l, eff_pivot_r)
s1_pl        = ta.pivotlow(low,   eff_pivot_l, eff_pivot_r)
s1_zone_half = atr14 * eff_zatr * 0.5

// --- Register supply zone on pivot high
if i_s1_enable and not na(s1_ph)
    array.push(s1_sz_top,   s1_ph + s1_zone_half)
    array.push(s1_sz_bot,   s1_ph - s1_zone_half)
    array.push(s1_sz_bar,   bar_index - i_s1_pivot_r)
    array.push(s1_sz_alive, true)
    array.push(s1_sz_uses,  0)
    if array.size(s1_sz_top) > i_s1_max_zones
        array.shift(s1_sz_top)
        array.shift(s1_sz_bot)
        array.shift(s1_sz_bar)
        array.shift(s1_sz_alive)
        array.shift(s1_sz_uses)

// --- Register demand zone on pivot low
if i_s1_enable and not na(s1_pl)
    array.push(s1_dz_top,   s1_pl + s1_zone_half)
    array.push(s1_dz_bot,   s1_pl - s1_zone_half)
    array.push(s1_dz_bar,   bar_index - i_s1_pivot_r)
    array.push(s1_dz_alive, true)
    array.push(s1_dz_uses,  0)
    if array.size(s1_dz_top) > i_s1_max_zones
        array.shift(s1_dz_top)
        array.shift(s1_dz_bot)
        array.shift(s1_dz_bar)
        array.shift(s1_dz_alive)
        array.shift(s1_dz_uses)

// --- Invalidate on body close-through
if i_s1_enable and i_s1_inval
    if array.size(s1_sz_alive) > 0
        for i = 0 to array.size(s1_sz_alive) - 1
            if array.get(s1_sz_alive, i) and close > array.get(s1_sz_top, i)
                array.set(s1_sz_alive, i, false)
    if array.size(s1_dz_alive) > 0
        for i = 0 to array.size(s1_dz_alive) - 1
            if array.get(s1_dz_alive, i) and close < array.get(s1_dz_bot, i)
                array.set(s1_dz_alive, i, false)

// --- Entry signals (tracks which zone index triggered, for use-count bookkeeping)
s1_in_supply = false
s1_in_demand = false
var int s1_sz_hit_idx = -1
var int s1_dz_hit_idx = -1
s1_sz_hit_idx := -1
s1_dz_hit_idx := -1

if i_s1_enable
    if array.size(s1_sz_alive) > 0
        for i = 0 to array.size(s1_sz_alive) - 1
            if array.get(s1_sz_alive, i)
                zt = array.get(s1_sz_top, i)
                zb = array.get(s1_sz_bot, i)
                _hit = eff_touch == "Wick Touch" ? (high >= zb and low <= zt) : eff_touch == "Rejection Bar" ? (high >= zb and close < (high + low) / 2 and close <= zt) : (close >= zb and close <= zt)
                if _hit
                    s1_in_supply  := true
                    s1_sz_hit_idx := i

    if array.size(s1_dz_alive) > 0
        for i = 0 to array.size(s1_dz_alive) - 1
            if array.get(s1_dz_alive, i)
                zt = array.get(s1_dz_top, i)
                zb = array.get(s1_dz_bot, i)
                _hit = eff_touch == "Wick Touch" ? (high >= zb and low <= zt) : eff_touch == "Rejection Bar" ? (low <= zt and close > (high + low) / 2 and close >= zb) : (close >= zb and close <= zt)
                if _hit
                    s1_in_demand  := true
                    s1_dz_hit_idx := i

s1_sig_long  = i_s1_enable and i_s1_longs  and s1_in_demand
s1_sig_short = i_s1_enable and i_s1_shorts and s1_in_supply

// --- Minimum room to opposing zone check
// Long: nearest alive supply zone bottom must be >= min_room ticks above close
// Short: nearest alive demand zone top must be >= min_room ticks below close
_room_dist   = i_s1_min_room * syminfo.mintick
room_ok_long  = true
room_ok_short = true
if i_s1_min_room > 0
    if array.size(s1_sz_alive) > 0
        for i = 0 to array.size(s1_sz_alive) - 1
            if array.get(s1_sz_alive, i)
                _sb = array.get(s1_sz_bot, i)
                if _sb > close and _sb - close < _room_dist
                    room_ok_long := false
    if array.size(s1_dz_alive) > 0
        for i = 0 to array.size(s1_dz_alive) - 1
            if array.get(s1_dz_alive, i)
                _dt = array.get(s1_dz_top, i)
                if _dt < close and close - _dt < _room_dist
                    room_ok_short := false

// --- Zone Visualization
var box[] s1_s_boxes = array.new_box()
var box[] s1_d_boxes = array.new_box()

if i_s1_enable and barstate.islast
    for b in s1_s_boxes
        box.delete(b)
    array.clear(s1_s_boxes)
    for b in s1_d_boxes
        box.delete(b)
    array.clear(s1_d_boxes)

    if array.size(s1_sz_alive) > 0
        for i = 0 to array.size(s1_sz_alive) - 1
            if array.get(s1_sz_alive, i)
                b = box.new(left=array.get(s1_sz_bar, i), top=array.get(s1_sz_top, i),
                     right=bar_index + i_s1_extend, bottom=array.get(s1_sz_bot, i),
                     bgcolor=color.new(color.red, i_s1_transp_z),
                     border_color=color.new(color.red, 50), border_width=1)
                array.push(s1_s_boxes, b)

    if array.size(s1_dz_alive) > 0
        for i = 0 to array.size(s1_dz_alive) - 1
            if array.get(s1_dz_alive, i)
                b = box.new(left=array.get(s1_dz_bar, i), top=array.get(s1_dz_top, i),
                     right=bar_index + i_s1_extend, bottom=array.get(s1_dz_bot, i),
                     bgcolor=color.new(color.green, i_s1_transp_z),
                     border_color=color.new(color.green, 50), border_width=1)
                array.push(s1_d_boxes, b)

// ================================================================
// ================================================================
// === [ADD MODULE 2 HERE]
// ================================================================
// ================================================================
// Pattern:
//   var g_s2     = "Strategy Name"
//   i_s2_enable  = input.bool(false, "--- Enable Strategy 2 ---", group=g_s2)
//   ... inputs, calculations, signals ...
//   s2_sig_long  = i_s2_enable and <your logic>
//   s2_sig_short = i_s2_enable and <your logic>

// ================================================================
// === SIGNAL AGGREGATION
// ================================================================
// To add module 2: append "or s2_sig_long" / "or s2_sig_short" at the end of each line
final_sig_long  = in_bt_window and no_position and cooldown_ok and room_ok_long  and in_session and trend_ok_long  and s1_sig_long
final_sig_short = in_bt_window and no_position and cooldown_ok and room_ok_short and in_session and trend_ok_short and s1_sig_short

// ================================================================
// === SHARED - Trade Execution
// ================================================================

long_sl  = close - sl_dist
long_tp  = close + tp_dist
short_sl = close + sl_dist
short_tp = close - tp_dist

// Risk-based position size: lose exactly (equity * risk_pct%) if SL hits
_risk_usd = strategy.equity * i_risk_pct / 100
_pv       = syminfo.pointvalue > 0 ? syminfo.pointvalue : 1.0
_qty      = math.max(_risk_usd / (sl_dist * _pv), syminfo.mintick)

if final_sig_long
    strategy.entry("Long", strategy.long, qty=_qty, comment="BUY NOW")
    _entry_tp       := long_tp
    _entry_sl       := long_sl
    _last_entry_bar := bar_index
    if s1_dz_hit_idx >= 0 and s1_dz_hit_idx < array.size(s1_dz_uses)
        _u = array.get(s1_dz_uses, s1_dz_hit_idx) + 1
        array.set(s1_dz_uses, s1_dz_hit_idx, _u)
        if _u >= i_s1_max_uses
            array.set(s1_dz_alive, s1_dz_hit_idx, false)

if final_sig_short
    strategy.entry("Short", strategy.short, qty=_qty, comment="SELL NOW")
    _entry_tp       := short_tp
    _entry_sl       := short_sl
    _last_entry_bar := bar_index
    if s1_sz_hit_idx >= 0 and s1_sz_hit_idx < array.size(s1_sz_uses)
        _u = array.get(s1_sz_uses, s1_sz_hit_idx) + 1
        array.set(s1_sz_uses, s1_sz_hit_idx, _u)
        if _u >= i_s1_max_uses
            array.set(s1_sz_alive, s1_sz_hit_idx, false)

if strategy.position_size > 0
    if i_use_trail
        strategy.exit("Long Exit", "Long",
             trail_points=math.round(atr14 * i_trail_mult / syminfo.mintick),
             trail_offset=math.round(atr14 * i_trail_mult / syminfo.mintick))
    else
        strategy.exit("Long Exit", "Long", limit=_entry_tp, stop=_entry_sl)

if strategy.position_size < 0
    if i_use_trail
        strategy.exit("Short Exit", "Short",
             trail_points=math.round(atr14 * i_trail_mult / syminfo.mintick),
             trail_offset=math.round(atr14 * i_trail_mult / syminfo.mintick))
    else
        strategy.exit("Short Exit", "Short", limit=_entry_tp, stop=_entry_sl)

// ================================================================
// === SHARED - Visual Engine
// ================================================================

// Moving averages
plot(i_show_mas ? fast_ma : na, "Fast MA", color=color.new(color.aqua, 20), linewidth=1)
plot(i_show_mas ? slow_ma : na, "Slow MA", color=color.new(color.orange, 20), linewidth=2)

// BUY / SELL labels - edge only: show on first bar signal fires, not on every repeat
if i_show_labels
    if final_sig_long and not final_sig_long[1]
        label.new(bar_index, low - atr14 * 0.8, "BUY NOW",
             style=label.style_label_up, color=color.new(color.green, 5),
             textcolor=color.white, size=size.normal)
    if final_sig_short and not final_sig_short[1]
        label.new(bar_index, high + atr14 * 0.8, "SELL NOW",
             style=label.style_label_down, color=color.new(color.red, 5),
             textcolor=color.white, size=size.normal)

// ----------------------------------------------------------------
// R/R Trade Visual - array-based, all historical boxes persist
// Each trade pushes new objects into arrays. No deletes on entry.
// Current trade extends right each bar; closed trades freeze.
// ----------------------------------------------------------------

var line[]   _v_elines  = array.new<line>()
var line[]   _v_slines  = array.new<line>()
var line[]   _v_tlines  = array.new<line>()
var box[]    _v_tpboxes = array.new<box>()
var box[]    _v_slboxes = array.new<box>()
var label[]  _v_tplbls  = array.new<label>()
var label[]  _v_sllbls  = array.new<label>()
var label[]  _v_ctrlbls = array.new<label>()
var float[]  _v_eps     = array.new<float>()
var float[]  _v_sls     = array.new<float>()
var float[]  _v_tps     = array.new<float>()
var string[] _v_dirs    = array.new<string>()
var bool     _v_in_trade  = false
var int      _v_cur       = -1
var int      _v_entry_bar = -1

// On entry signal: push new visual objects (previous boxes stay)
if i_show_rr and (final_sig_long or final_sig_short)
    _ep  = close
    _sl  = final_sig_long ? long_sl : short_sl
    _tp  = final_sig_long ? long_tp : short_tp
    _dir = final_sig_long ? "long" : "short"
    _bx  = bar_index
    _c_tp = color.new(color.teal, i_transp_box)
    _c_sl = color.new(color.red,  i_transp_box)

    _tp_pct = str.tostring(math.abs(_tp - _ep) / _ep * 100, "#.###") + "%"
    _sl_pct = str.tostring(math.abs(_ep - _sl) / _ep * 100, "#.###") + "%"
    _tp_amt = str.tostring(math.abs(_tp - _ep) * _qty, "#.##")
    _sl_amt = str.tostring(math.abs(_ep - _sl) * _qty, "#.##")
    _tp_txt = "TP: " + str.tostring(_tp, format.mintick) + " (" + _tp_pct + ")  $" + _tp_amt
    _sl_txt = "SL: " + str.tostring(_sl, format.mintick) + " (" + _sl_pct + ")  $" + _sl_amt

    _eline = line.new(_bx, _ep, _bx, _ep, color=color.new(color.white, 30), width=1, style=line.style_dashed)
    _sline = line.new(_bx, _sl, _bx, _sl, color=color.new(color.red,   20), width=1, style=line.style_dashed)
    _tline = line.new(_bx, _tp, _bx, _tp, color=color.new(color.teal,  20), width=1, style=line.style_dashed)

    _tpbox = _dir == "long" ? box.new(_bx, _tp, _bx + 1, _ep, bgcolor=_c_tp, border_color=color.new(color.teal, 30), border_width=1) : box.new(_bx, _ep, _bx + 1, _tp, bgcolor=_c_tp, border_color=color.new(color.teal, 30), border_width=1)
    _slbox = _dir == "long" ? box.new(_bx, _ep, _bx + 1, _sl, bgcolor=_c_sl, border_color=color.new(color.red,  30), border_width=1) : box.new(_bx, _sl, _bx + 1, _ep, bgcolor=_c_sl, border_color=color.new(color.red,  30), border_width=1)
    _tplbl = _dir == "long" ? label.new(_bx + 2, _tp, _tp_txt, style=label.style_label_lower_left, color=color.new(color.teal, 10), textcolor=color.white, size=size.small) : label.new(_bx + 2, _tp, _tp_txt, style=label.style_label_upper_left, color=color.new(color.teal, 10), textcolor=color.white, size=size.small)
    _sllbl = _dir == "long" ? label.new(_bx + 2, _sl, _sl_txt, style=label.style_label_upper_left, color=color.new(color.red,  10), textcolor=color.white, size=size.small) : label.new(_bx + 2, _sl, _sl_txt, style=label.style_label_lower_left, color=color.new(color.red,  10), textcolor=color.white, size=size.small)
    _ctrlbl = label.new(_bx + 2, (_tp + _sl) / 2, "PyG Apertura: 0.00", style=label.style_label_left, color=color.new(color.gray, 30), textcolor=color.white, size=size.small)

    array.push(_v_elines,  _eline)
    array.push(_v_slines,  _sline)
    array.push(_v_tlines,  _tline)
    array.push(_v_tpboxes, _tpbox)
    array.push(_v_slboxes, _slbox)
    array.push(_v_tplbls,  _tplbl)
    array.push(_v_sllbls,  _sllbl)
    array.push(_v_ctrlbls, _ctrlbl)
    array.push(_v_eps,     _ep)
    array.push(_v_sls,     _sl)
    array.push(_v_tps,     _tp)
    array.push(_v_dirs,    _dir)

    _v_in_trade  := true
    _v_cur       := array.size(_v_elines) - 1
    _v_entry_bar := bar_index

// Extend current trade lines + boxes each bar; update live P&L
if i_show_rr and _v_in_trade and _v_cur >= 0 and strategy.position_size != 0
    line.set_x2(array.get(_v_elines,  _v_cur), bar_index)
    line.set_x2(array.get(_v_slines,  _v_cur), bar_index)
    line.set_x2(array.get(_v_tlines,  _v_cur), bar_index)
    box.set_right(array.get(_v_tpboxes, _v_cur), bar_index + 1)
    box.set_right(array.get(_v_slboxes, _v_cur), bar_index + 1)

    _ep_c  = array.get(_v_eps,  _v_cur)
    _sl_c  = array.get(_v_sls,  _v_cur)
    _tp_c  = array.get(_v_tps,  _v_cur)
    _dir_c = array.get(_v_dirs, _v_cur)
    _qty_live = math.abs(strategy.position_size)
    _open_pnl = _dir_c == "long" ? (close - _ep_c) * _qty_live : (_ep_c - close) * _qty_live
    _is_pos   = _open_pnl >= 0
    _ctr_txt  = "PyG Apertura: " + (_is_pos ? "+" : "") + str.tostring(_open_pnl, "#.##") + "  Qty: " + str.tostring(_qty_live, "#.###") + "\nR/R: " + str.tostring(eff_rr_v, "#.#")

    _x = bar_index + 2
    label.set_xy(array.get(_v_tplbls,  _v_cur), _x, _tp_c)
    label.set_xy(array.get(_v_sllbls,  _v_cur), _x, _sl_c)
    label.set_xy(array.get(_v_ctrlbls, _v_cur), _x, (_tp_c + _sl_c) / 2)
    label.set_text(array.get(_v_ctrlbls, _v_cur), _ctr_txt)
    label.set_color(array.get(_v_ctrlbls, _v_cur), _is_pos ? color.new(color.teal, 15) : color.new(color.red, 15))

// On trade close: extend one final bar to include the exit bar, then freeze
// bar_index > _v_entry_bar prevents false-fire on signal bar (order fills next bar open)
if i_show_rr and _v_in_trade and _v_cur >= 0 and bar_index > _v_entry_bar and strategy.position_size == 0
    _tp_c = array.get(_v_tps, _v_cur)
    _sl_c = array.get(_v_sls, _v_cur)
    box.set_right(array.get(_v_tpboxes, _v_cur), bar_index + 1)
    box.set_right(array.get(_v_slboxes, _v_cur), bar_index + 1)
    line.set_x2(array.get(_v_elines, _v_cur), bar_index)
    line.set_x2(array.get(_v_slines, _v_cur), bar_index)
    line.set_x2(array.get(_v_tlines, _v_cur), bar_index)
    _x = bar_index + 2
    label.set_xy(array.get(_v_tplbls,  _v_cur), _x, _tp_c)
    label.set_xy(array.get(_v_sllbls,  _v_cur), _x, _sl_c)
    label.set_xy(array.get(_v_ctrlbls, _v_cur), _x, (_tp_c + _sl_c) / 2)
    n = strategy.closedtrades
    if n > 0
        pnl    = strategy.closedtrades.profit(n - 1)
        qty    = math.abs(strategy.closedtrades.size(n - 1))
        is_win = pnl > 0
        res_txt = "PyG Cerrado: " + (is_win ? "+" : "") + str.tostring(pnl, "#.##") + "  Qty: " + str.tostring(qty, "#.###") + "\nR/R: " + str.tostring(eff_rr_v, "#.#")
        label.set_text(array.get(_v_ctrlbls, _v_cur), res_txt)
        label.set_color(array.get(_v_ctrlbls, _v_cur), is_win ? color.new(color.teal, 10) : color.new(color.red, 10))
    _v_in_trade := false

// ================================================================
// === SHARED - Debug Output
// ================================================================

if i_debug and barstate.islast
    dbg_txt = "ATR=" + str.tostring(atr14, "#.####") +
         " | Trend=" + (bull_bias ? "BULL" : "BEAR") +
         " | Session=" + str.tostring(in_session) +
         " | BT window=" + str.tostring(in_bt_window) +
         "\n[S1] enabled=" + str.tostring(i_s1_enable) +
         " | supply=" + str.tostring(array.size(s1_sz_alive)) +
         " | demand=" + str.tostring(array.size(s1_dz_alive)) +
         " | in_supply=" + str.tostring(s1_in_supply) +
         " | in_demand=" + str.tostring(s1_in_demand)
    label.new(bar_index, high + atr14 * 3, dbg_txt,
         style=label.style_label_down, color=color.new(color.gray, 30),
         textcolor=color.white, size=size.tiny)

// ================================================================
// === SHARED - Strategy Analyzer Table
// ================================================================

// --- Long/Short win/loss counters (updated on every new trade close)
var int _lw  = 0
var int _ll  = 0
var int _sw  = 0
var int _slo = 0

if strategy.closedtrades > nz(strategy.closedtrades[1], 0)
    _idx    = strategy.closedtrades - 1
    _is_lng = strategy.closedtrades.size(_idx) > 0
    _is_win = strategy.closedtrades.profit(_idx) > 0
    if _is_lng
        _lw  := _lw  + (_is_win ? 1 : 0)
        _ll  := _ll  + (_is_win ? 0 : 1)
    else
        _sw  := _sw  + (_is_win ? 1 : 0)
        _slo := _slo + (_is_win ? 0 : 1)

// Colors (global scope - used across all three analyzer blocks below)
C_HDR = color.new(color.gray,   50)
C_BG  = color.new(color.black,  15)
C_YEL = color.new(color.yellow, 20)
C_WHT = color.white
C_GRN = color.new(color.green,  10)
C_ORG = color.new(color.orange, 10)
C_RED = color.new(color.red,    10)
C_FTR = color.new(color.gray,   75)

// --- Table object: created once, never deleted
// Old values freeze in place while a new bar is forming (no blanking/clearing)
var table _atbl = na

// --- BLOCK 1: Build static skeleton on first bar only
// Sets labels and suggested values (TF-based, constant per chart load)
if i_show_table and na(_atbl)
    _tf0    = timeframe.period
    r0_piv  = _tf0 == "1" ? 3 : _tf0 == "3" ? 3 : _tf0 == "5" ? 4 : _tf0 == "15" ? 5 : _tf0 == "30" ? 6 : _tf0 == "60" ? 7 : _tf0 == "240" ? 8 : 5
    r0_zatr = _tf0 == "1" ? 0.3 : _tf0 == "3" ? 0.35 : _tf0 == "5" ? 0.4 : _tf0 == "15" ? 0.5 : _tf0 == "30" ? 0.6 : _tf0 == "60" ? 0.7 : _tf0 == "240" ? 0.8 : 0.5
    r0_sl   = _tf0 == "1" ? 1.0 : _tf0 == "3" ? 1.0 : _tf0 == "5" ? 1.2 : _tf0 == "15" ? 1.5 : _tf0 == "30" ? 1.8 : _tf0 == "60" ? 2.0 : _tf0 == "240" ? 2.5 : 1.5
    r0_rr   = _tf0 == "1" ? 1.5 : _tf0 == "3" ? 1.5 : _tf0 == "5" ? 1.8 : _tf0 == "15" ? 2.0 : _tf0 == "30" ? 2.0 : _tf0 == "60" ? 2.5 : _tf0 == "240" ? 2.5 : 2.0
    r0_tch  = (_tf0 == "1" or _tf0 == "3" or _tf0 == "5") ? "Reject" : "Wick"

    _atbl := table.new(position.bottom_right, 3, 18, border_width=1,
         border_color=color.new(color.gray, 60), frame_width=1,
         frame_color=color.new(color.gray, 40))

    // Row 0 - Header (col 2 = status cell, updated every tick by BLOCK 2)
    table.cell(_atbl, 0, 0, "AAC STRATEGY ANALYZER", bgcolor=C_HDR, text_color=C_YEL, text_size=size.small, text_halign=text.align_left)
    table.cell(_atbl, 1, 0, "CURRENT", bgcolor=C_HDR, text_color=C_YEL, text_size=size.small, text_halign=text.align_center)
    table.cell(_atbl, 2, 0, "[ ~ ]", bgcolor=C_HDR, text_color=C_ORG, text_size=size.small, text_halign=text.align_center)

    // Row 1 - Performance section header
    table.cell(_atbl, 0, 1, "PERFORMANCE  |  TF: " + _tf0, bgcolor=C_HDR, text_color=C_WHT, text_size=size.tiny, text_halign=text.align_left)
    table.cell(_atbl, 1, 1, "", bgcolor=C_HDR, text_color=C_WHT, text_size=size.tiny, text_halign=text.align_center)
    table.cell(_atbl, 2, 1, "", bgcolor=C_HDR, text_color=C_WHT, text_size=size.tiny, text_halign=text.align_center)

    // Rows 2-8: label column only (data cols filled by BLOCK 3 on bar close)
    table.cell(_atbl, 0, 2, "Total Trades",  bgcolor=C_BG, text_color=C_WHT, text_size=size.tiny, text_halign=text.align_left)
    table.cell(_atbl, 0, 3, "Win Rate",       bgcolor=C_BG, text_color=C_WHT, text_size=size.tiny, text_halign=text.align_left)
    table.cell(_atbl, 0, 4, "Profit Factor",  bgcolor=C_BG, text_color=C_WHT, text_size=size.tiny, text_halign=text.align_left)
    table.cell(_atbl, 0, 5, "Net Profit",     bgcolor=C_BG, text_color=C_WHT, text_size=size.tiny, text_halign=text.align_left)
    table.cell(_atbl, 0, 6, "Max Drawdown",   bgcolor=C_BG, text_color=C_WHT, text_size=size.tiny, text_halign=text.align_left)
    table.cell(_atbl, 0, 7, "Long Win Rate",  bgcolor=C_BG, text_color=C_WHT, text_size=size.tiny, text_halign=text.align_left)
    table.cell(_atbl, 0, 8, "Short Win Rate", bgcolor=C_BG, text_color=C_WHT, text_size=size.tiny, text_halign=text.align_left)

    // Row 9 - Recommendations section header
    table.cell(_atbl, 0, 9, "RECOMMENDATIONS  |  TF: " + _tf0, bgcolor=C_HDR, text_color=C_WHT, text_size=size.tiny, text_halign=text.align_left)
    table.cell(_atbl, 1, 9, "CURRENT", bgcolor=C_HDR, text_color=C_WHT, text_size=size.tiny, text_halign=text.align_center)
    table.cell(_atbl, 2, 9, "SUGGESTED", bgcolor=C_HDR, text_color=C_WHT, text_size=size.tiny, text_halign=text.align_center)

    // Rows 10-15: label + suggested columns (static); current col filled by BLOCK 3
    table.cell(_atbl, 0, 10, "Pivot Bars L/R", bgcolor=C_BG, text_color=C_WHT, text_size=size.tiny, text_halign=text.align_left)
    table.cell(_atbl, 2, 10, str.tostring(r0_piv) + "/" + str.tostring(r0_piv), bgcolor=C_BG, text_color=C_WHT, text_size=size.tiny, text_halign=text.align_center)
    table.cell(_atbl, 0, 11, "Zone Width ATR", bgcolor=C_BG, text_color=C_WHT, text_size=size.tiny, text_halign=text.align_left)
    table.cell(_atbl, 2, 11, str.tostring(r0_zatr, "#.##"), bgcolor=C_BG, text_color=C_WHT, text_size=size.tiny, text_halign=text.align_center)
    table.cell(_atbl, 0, 12, "SL Mult ATR",    bgcolor=C_BG, text_color=C_WHT, text_size=size.tiny, text_halign=text.align_left)
    table.cell(_atbl, 2, 12, str.tostring(r0_sl, "#.#"), bgcolor=C_BG, text_color=C_WHT, text_size=size.tiny, text_halign=text.align_center)
    table.cell(_atbl, 0, 13, "R/R Ratio",      bgcolor=C_BG, text_color=C_WHT, text_size=size.tiny, text_halign=text.align_left)
    table.cell(_atbl, 2, 13, str.tostring(r0_rr, "#.#"), bgcolor=C_BG, text_color=C_WHT, text_size=size.tiny, text_halign=text.align_center)
    table.cell(_atbl, 0, 14, "Entry Trigger",  bgcolor=C_BG, text_color=C_WHT, text_size=size.tiny, text_halign=text.align_left)
    table.cell(_atbl, 2, 14, r0_tch, bgcolor=C_BG, text_color=C_WHT, text_size=size.tiny, text_halign=text.align_center)
    table.cell(_atbl, 0, 15, "Trend Filter",   bgcolor=C_BG, text_color=C_WHT, text_size=size.tiny, text_halign=text.align_left)
    table.cell(_atbl, 2, 15, "ON", bgcolor=C_BG, text_color=C_WHT, text_size=size.tiny, text_halign=text.align_center)
    table.cell(_atbl, 0, 16, "Config Score",   bgcolor=C_BG, text_color=C_WHT, text_size=size.small, text_halign=text.align_left)

    // Row 17 - Footer: risk per trade + break-even WR (data filled by BLOCK 3)
    table.cell(_atbl, 0, 17, "Risk/trade  |  Break-even WR", bgcolor=C_FTR, text_color=color.new(color.gray, 20), text_size=size.tiny, text_halign=text.align_left)
    table.cell(_atbl, 1, 17, "...", bgcolor=C_FTR, text_color=C_WHT, text_size=size.tiny, text_halign=text.align_center)
    table.cell(_atbl, 2, 17, "...", bgcolor=C_FTR, text_color=C_WHT, text_size=size.tiny, text_halign=text.align_center)

// --- BLOCK 2: Status indicator - updates on every tick (only the [ ~ ] cell)
// Shows [ ~ ] while bar is forming, [ OK ] the instant the bar closes
if i_show_table and barstate.islast and not na(_atbl)
    _live = not barstate.isconfirmed
    table.cell(_atbl, 2, 0, _live ? "[ ~ ]" : "[ OK ]",
         bgcolor=C_HDR, text_color=_live ? C_ORG : C_GRN,
         text_size=size.small, text_halign=text.align_center)

// --- BLOCK 3: Data cells - update only on confirmed bar close
// While new bar is forming these cells are frozen (no blank flash, values usable as history)
if i_show_table and barstate.isconfirmed and not na(_atbl)
    _total  = strategy.closedtrades
    _wr     = _total > 0 ? strategy.wintrades / _total * 100 : 0.0
    _pf     = strategy.grossloss != 0 ? strategy.grossprofit / math.abs(strategy.grossloss) : 0.0
    _netp   = strategy.netprofit
    _dd_pct = strategy.initial_capital != 0 ? strategy.max_drawdown / strategy.initial_capital * 100 : 0.0
    _lt     = _lw + _ll
    _st     = _sw + _slo
    _lwr    = _lt > 0 ? _lw / _lt * 100 : 0.0
    _swr    = _st > 0 ? _sw / _st * 100 : 0.0

    // Match: compare effective (active) values against TF-based suggested values
    m_piv   = eff_pivot_l == _as_piv and eff_pivot_r == _as_piv
    m_zatr  = math.abs(eff_zatr  - _as_zatr) < 0.05
    m_sl    = math.abs(eff_sl_m  - _as_sl)   < 0.1
    m_rr    = math.abs(eff_rr_v  - _as_rr)   < 0.1
    m_tch   = eff_touch == _as_tch
    m_tr    = i_use_trend
    _score  = (m_piv ? 1 : 0) + (m_zatr ? 1 : 0) + (m_sl ? 1 : 0) + (m_rr ? 1 : 0) + (m_tch ? 1 : 0) + (m_tr ? 1 : 0)

    // Auto-suggest header (shows [AUTO ON] when active)
    _as_hdr = i_auto_suggest ? "RECOMMENDATIONS  |  TF: " + _as_tf + "  [AUTO ON]" : "RECOMMENDATIONS  |  TF: " + _as_tf
    table.cell(_atbl, 0, 9, _as_hdr, bgcolor=C_HDR, text_color=i_auto_suggest ? C_GRN : C_WHT, text_size=size.tiny, text_halign=text.align_left)

    // Performance data cols
    table.cell(_atbl, 1, 2, str.tostring(_total), bgcolor=C_BG, text_color=C_WHT, text_size=size.tiny, text_halign=text.align_center)
    table.cell(_atbl, 2, 2, _total >= 30 ? "OK" : "FEW TRADES", bgcolor=C_BG, text_color=_total >= 30 ? C_GRN : C_ORG, text_size=size.tiny, text_halign=text.align_center)
    table.cell(_atbl, 1, 3, str.tostring(_wr, "#.1") + "%", bgcolor=C_BG, text_color=C_WHT, text_size=size.tiny, text_halign=text.align_center)
    table.cell(_atbl, 2, 3, _wr >= 55 ? "GOOD >55%" : _wr >= 50 ? "OK >50%" : "LOW <50%", bgcolor=C_BG, text_color=_wr >= 55 ? C_GRN : _wr >= 50 ? C_ORG : C_RED, text_size=size.tiny, text_halign=text.align_center)
    table.cell(_atbl, 1, 4, str.tostring(_pf, "#.##"), bgcolor=C_BG, text_color=C_WHT, text_size=size.tiny, text_halign=text.align_center)
    table.cell(_atbl, 2, 4, _pf >= 1.5 ? "GOOD >1.5" : _pf >= 1.0 ? "OK >1.0" : "LOSS <1.0", bgcolor=C_BG, text_color=_pf >= 1.5 ? C_GRN : _pf >= 1.0 ? C_ORG : C_RED, text_size=size.tiny, text_halign=text.align_center)
    table.cell(_atbl, 1, 5, (_netp >= 0 ? "+" : "") + str.tostring(_netp, "#.00"), bgcolor=C_BG, text_color=C_WHT, text_size=size.tiny, text_halign=text.align_center)
    table.cell(_atbl, 2, 5, _netp > 0 ? "PROFIT" : "LOSS", bgcolor=C_BG, text_color=_netp > 0 ? C_GRN : C_RED, text_size=size.tiny, text_halign=text.align_center)
    table.cell(_atbl, 1, 6, str.tostring(_dd_pct, "#.1") + "%", bgcolor=C_BG, text_color=C_WHT, text_size=size.tiny, text_halign=text.align_center)
    table.cell(_atbl, 2, 6, _dd_pct <= 10 ? "OK <10%" : _dd_pct <= 20 ? "WATCH <20%" : "HIGH >20%", bgcolor=C_BG, text_color=_dd_pct <= 10 ? C_GRN : _dd_pct <= 20 ? C_ORG : C_RED, text_size=size.tiny, text_halign=text.align_center)
    table.cell(_atbl, 1, 7, str.tostring(_lwr, "#.1") + "% (" + str.tostring(_lt) + ")", bgcolor=C_BG, text_color=C_WHT, text_size=size.tiny, text_halign=text.align_center)
    table.cell(_atbl, 2, 7, _lwr >= 55 ? "GOOD" : _lwr >= 50 ? "OK" : "LOW", bgcolor=C_BG, text_color=_lwr >= 55 ? C_GRN : _lwr >= 50 ? C_ORG : C_RED, text_size=size.tiny, text_halign=text.align_center)
    table.cell(_atbl, 1, 8, str.tostring(_swr, "#.1") + "% (" + str.tostring(_st) + ")", bgcolor=C_BG, text_color=C_WHT, text_size=size.tiny, text_halign=text.align_center)
    table.cell(_atbl, 2, 8, _swr >= 55 ? "GOOD" : _swr >= 50 ? "OK" : "LOW", bgcolor=C_BG, text_color=_swr >= 55 ? C_GRN : _swr >= 50 ? C_ORG : C_RED, text_size=size.tiny, text_halign=text.align_center)

    // Recommendations current cols (show effective/active values)
    _cur_tch = eff_touch == "Wick Touch" ? "Wick" : eff_touch == "Rejection Bar" ? "Reject" : "Body"
    table.cell(_atbl, 1, 10, str.tostring(eff_pivot_l) + "/" + str.tostring(eff_pivot_r), bgcolor=C_BG, text_color=m_piv ? C_GRN : C_ORG, text_size=size.tiny, text_halign=text.align_center)
    table.cell(_atbl, 1, 11, str.tostring(eff_zatr, "#.##"), bgcolor=C_BG, text_color=m_zatr ? C_GRN : C_ORG, text_size=size.tiny, text_halign=text.align_center)
    table.cell(_atbl, 1, 12, str.tostring(eff_sl_m, "#.#"), bgcolor=C_BG, text_color=m_sl ? C_GRN : C_ORG, text_size=size.tiny, text_halign=text.align_center)
    table.cell(_atbl, 1, 13, str.tostring(eff_rr_v, "#.#"), bgcolor=C_BG, text_color=m_rr ? C_GRN : C_ORG, text_size=size.tiny, text_halign=text.align_center)
    table.cell(_atbl, 1, 14, _cur_tch, bgcolor=C_BG, text_color=m_tch ? C_GRN : C_ORG, text_size=size.tiny, text_halign=text.align_center)
    table.cell(_atbl, 1, 15, i_use_trend ? "ON" : "OFF", bgcolor=C_BG, text_color=m_tr ? C_GRN : C_ORG, text_size=size.tiny, text_halign=text.align_center)

    // Config score
    _s_col = _score >= 5 ? C_GRN : _score >= 3 ? C_ORG : C_RED
    _s_lbl = _score >= 5 ? "OPTIMAL" : _score >= 3 ? "ADJUST" : "REVIEW"
    table.cell(_atbl, 1, 16, str.tostring(_score) + " / 6", bgcolor=C_BG, text_color=_s_col, text_size=size.small, text_halign=text.align_center)
    table.cell(_atbl, 2, 16, _s_lbl, bgcolor=C_BG, text_color=_s_col, text_size=size.small, text_halign=text.align_center)

    // Row 17 - Risk per trade + break-even win rate
    _risk_disp  = strategy.equity * i_risk_pct / 100
    _be_wr      = 1.0 / (1.0 + eff_rr_v) * 100
    _be_col     = _wr >= _be_wr ? C_GRN : C_RED
    table.cell(_atbl, 1, 17, "$" + str.tostring(_risk_disp, "#.##"), bgcolor=C_FTR, text_color=C_WHT, text_size=size.tiny, text_halign=text.align_center)
    table.cell(_atbl, 2, 17, str.tostring(_be_wr, "#.1") + "%", bgcolor=C_FTR, text_color=_be_col, text_size=size.tiny, text_halign=text.align_center)
